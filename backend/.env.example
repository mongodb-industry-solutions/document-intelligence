# FSI Document Intelligence Environment Variables

# MongoDB Configuration (REQUIRED)
MONGODB_URI=your_mongodb_uri_here
DATABASE_NAME=document_intelligence
APP_NAME=document-intelligence-backend

# VoyageAI Configuration (REQUIRED)
VOYAGE_API_KEY=your-voyage-api-key-here

# AWS Configuration (REQUIRED for S3 and Bedrock)
AWS_REGION=us-east-1
# Optional: If using AWS SSO (recommended)
#AWS_PROFILE=your-sso-profile-name

# Bedrock Model Configuration (REQUIRED)
# Main model for Q&A, vision extraction, reports
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
# Fast model for document grading and query rewriting
BEDROCK_FAST_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# All other variables have sensible defaults
# See README.md for complete list
